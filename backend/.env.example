# Server Configuration
PORT=5000
NODE_ENV=development

# Security / CORS Configuration
FRONTEND_URL=http://localhost:3000

# Supabase / PostgreSQL Connection Configuration
# In Phase 2, connect directly to PostgreSQL or via the Supabase Client
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-private-key

# Database Connection String (Direct PostgreSQL access)
DATABASE_URL=postgresql://postgres:your-password@db.your-supabase-project.supabase.co:5432/postgres
